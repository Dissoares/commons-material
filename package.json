{
  "name": "commons-material",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tokens:sync": "node tools/gerar-tokens-scss.cjs",
    "build": "ng build commons-material",
    "prebuild": "npm run tokens:sync",
    "build:watch": "ng build commons-material --watch --configuration development",
    "build:prod": "ng build commons-material --configuration production",
    "pretest": "npm run tokens:sync",
    "test": "ng test commons-material",
    "lint": "eslint ."
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.18",
    "@angular/cli": "^20.3.15",
    "@angular/compiler-cli": "^20.3.0",
    "@eslint/js": "^9.32.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^20.3.0",
    "eslint": "^9.32.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "typescript-eslint": "^8.38.0",
    "typescript": "~5.9.2"
  }
}
